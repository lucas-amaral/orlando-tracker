# =============================================
#   ORLANDO TRACKER — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores

# --- Banco de dados (Supabase — plano free) ---
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJETO].supabase.co:5432/postgres

# --- Email de notificação ---
# Use uma conta Gmail. Gere uma "App Password" em:
# https://myaccount.google.com/apppasswords
GMAIL_USER=seu_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_EMAIL_TO=seu_email@gmail.com

# --- Configurações da viagem ---
ORIGIN_AIRPORT=POA
DESTINATION_AIRPORT=MCO
TRAVEL_MONTH_START=2027-01   # jan 2027
TRAVEL_MONTH_END=2027-02     # fev 2027
MIN_TRIP_DAYS=12
MAX_TRIP_DAYS=18
NUM_PASSENGERS=4

# --- Limites de alerta (em R$, total 4 pax, ida+volta) ---
FLIGHT_ALERT_THRESHOLD=14000    # Alerta se passagens 4 pax < R$14.000
DISNEY_ALERT_THRESHOLD=9000     # Alerta se 4 ingressos Disney 4 dias < R$9.000
UNIVERSAL_ALERT_THRESHOLD=7000  # Alerta se 4 ingressos Universal 3 dias < R$7.000

# --- Horários do cron (formato cron) ---
# Padrão: 7h e 19h horário de Brasília (UTC-3 → UTC+0 = 10h e 22h)
CRON_SCHEDULE_1=0 10 * * *
CRON_SCHEDULE_2=0 22 * * *

# --- Porta do servidor web (para keepalive no Render) ---
PORT=3000
